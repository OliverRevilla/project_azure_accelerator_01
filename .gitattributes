# Default: normalize line endings to LF in the repo
* text=auto eol=lf

# Shell scripts must always use LF (CRLF breaks bash on Linux/Mac/Cloud Shell)
*.sh text eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
